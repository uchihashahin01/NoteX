{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NoteX",
  "version": "0.1.0",
  "identifier": "com.notex.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NoteX",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "NoteX - Note Taking App"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1QTAwMEQ1NTVENDE1MjEKUldRaEZkUlYxUUNnOVNSYTdjalRsOHkzMEx5TGdYa0VXSDMwYW42UU96WGJSUEF4Z25UQXllNC8K",
      "endpoints": [
        "https://github.com/uchihashahin01/NoteX/releases/latest/download/latest.json"
      ]
    }
  }
}
